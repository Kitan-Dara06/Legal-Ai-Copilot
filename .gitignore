# Environment / secrets (never commit real env files)
.env
.env.*
!.env.example

# Virtualenvs / python junk
venv/
.venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Build / packaging artifacts
.dist/
.build/
build/
dist/

