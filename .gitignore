app/uploads/
logs/
*.log

# Celery beat schedule + pid files (generated)
celerybeat-schedule
celerybeat-schedule.db
celerybeat.pid

# Data created by running the app locally
legal_db/
results/
*.csv

# Large documents (keep out of git)
*.pdf

# OS / editor
.DS_Store
docker-compose.override.yml
