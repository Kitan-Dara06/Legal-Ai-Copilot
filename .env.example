# ─────────────────────────────────────────────────────────────
# Legal AI Copilot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────────────

# ── LLM Inference ────────────────────────────────────────────
# Groq Cloud API key (used for Qwen 3 32B reasoning)
GROQ_API_KEY=gsk_your_groq_key_here

# ── Embeddings ───────────────────────────────────────────────
# OpenRouter API key (used for BGE-M3 embeddings)
OPENROUTER_API_KEY=sk-or-v1-your_openrouter_key_here

# ── PostgreSQL Database ───────────────────────────────────────
# Used by FastAPI (asyncpg) and Celery tasks (psycopg2 sync pool)
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/legal_rag
DATABASE_URL_SYNC=postgresql://user:password@host:5432/legal_rag

# ── Redis / Upstash ──────────────────────────────────────────
# Used as Celery broker + result backend + session store
UPSTASH_HOST=your-upstash-host.upstash.io
UPSTASH_PORT=6379
UPSTASH_PASSWORD=your_upstash_password_here

# ── Qdrant Vector Database ───────────────────────────────────
# Qdrant Cloud REST endpoint and API key
QDRANT_URL=https://your-cluster-id.cloud.qdrant.io:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# ── Application ──────────────────────────────────────────────
# Public URL of the FastAPI backend (used by Streamlit frontend)
API_URL=http://localhost:8000
