# Docker ignore to keep images clean and avoid accidental secrets leaks.
.env
.env.*
!.env.example
.git
.gitignore
venv/
__pycache__/
*.pyc
*.pdf
*.log
logs/
results/
# scripts/ (Whitelisted for maintenance)
tests/
*.egg-info/
.mypy_cache/
.pytest_cache/
deploy/
certbot_challenge/
.dockerignore
*.md
